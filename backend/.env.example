# Database
MONGO_URL="mongodb+srv://username:password@host/db?retryWrites=true&w=majority"

# Auth
JWT_SECRET="replace-with-32+chars"
REFRESH_SECRET="replace-with-32+chars"

# Server
PORT=5000
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Frontend base URL (used in outbound emails for links like /login, /reset-password)
FRONTEND_URL="http://localhost:3000"

# Email (SMTP example)
EMAIL_PROVIDER=smtp
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="no-reply@example.com"
EMAIL_FROM_NAME="BrainScale CRM"
EMAIL_REPLY_TO="support@example.com"

# Email (SendGrid example)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=""

# Swagger
SWAGGER_ENABLED=true

# AI (optional)
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=""
AI_FEATURES="summary,sentiment"

# Optional
RATE_LIMIT_ENABLED=true
RESEND_API_KEY=""
CRON_SECRET=""

# Email Queue (optional; enabled by default)
EMAIL_QUEUE_ENABLED=true
EMAIL_QUEUE_BATCH_SIZE=5
EMAIL_RESEND_RATE_LIMIT=2
EMAIL_SMTP_RATE_LIMIT=10

# Schedule Task Sync (optional; daily task creation from schedules)
# Default timezone for scheduling (if workspace timezone not set)
SCHEDULE_TASK_SYNC_TIMEZONE=Asia/Dhaka
# Hour to send daily schedule tasks (0-23, in workspace timezone)
SCHEDULE_TASK_SYNC_HOUR=8
# Minute to send daily schedule tasks
SCHEDULE_TASK_SYNC_MINUTE=0

# Web Push Notifications (optional; for team chat mention notifications)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
