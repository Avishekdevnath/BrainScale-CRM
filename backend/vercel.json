{
  "version": 2,
  "routes": [
    {
      "src": "/api/v1/emails/process-scheduled",
      "dest": "/api/cron/process-scheduled.ts"
    },
    {
      "src": "/api/cron/email-worker",
      "dest": "/api/cron/email-worker.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    },
    "api/cron/process-scheduled.ts": {
      "maxDuration": 60
    },
    "api/cron/email-worker.ts": {
      "maxDuration": 9
    }
  },
  "crons": [
    {
      "path": "/api/cron/email-worker",
      "schedule": "0 9 * * *"
    }
  ]
}

